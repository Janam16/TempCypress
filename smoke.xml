<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="smoke" parallel="tests">
    <listeners>
    <listener class-name="rahulshetty.TestComponents.Listeners"/>
    </listeners>
    
    <test thread-count="5" name="Submit Form">
        <classes>
            <class name="rahulshetty.tests.TestSelenium"/>
        </classes>
    </test>

    <test thread-count="5" name="Submit Form Copy">
        <classes>
            <class name="rahulshetty.tests.TestSeleniumcopy"/>
        </classes>
    </test>
</suite>